# Copy to .env and fill in values. Never commit .env.

# Cerebras (OpenAI-compatible API) — used by baseline/baseline_cerebras.py
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Use a model ID from https://inference-docs.cerebras.ai/models (e.g. llama3.1-8b or gpt-oss-120b)
CEREBRAS_MODEL=llama3.1-8b

# Optional: first N questions from test.json (default 50)
NUM_QUESTIONS=50

# Legacy baselines
GROQ_API_KEY=
GEMINI_API_KEY=
