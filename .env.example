# Copy to .env and fill in values. Never commit .env.

# Cerebras (OpenAI-compatible API) — used by baseline/baseline_cerebras.py
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# Use a model ID from https://inference-docs.cerebras.ai/models (e.g. llama3.1-8b or gpt-oss-120b)
CEREBRAS_MODEL=llama3.1-8b
# Token limits (chain-of-thought needs a higher ceiling)
CEREBRAS_MAX_TOKENS=512
CEREBRAS_MAX_TOKENS_COT=1536

# OpenAI — used by baseline/baseline_openai.py and baseline/self_correction_openai.py
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Exact model id from https://platform.openai.com/docs/models (default: GPT-5.4 mini)
OPENAI_MODEL=gpt-5.4-mini
OPENAI_MAX_TOKENS=512
OPENAI_MAX_TOKENS_COT=1536

# Few-shot: K demonstrations from train_spider.json (same-db first, then random fill)
FEW_SHOT_K=3
FEW_SHOT_SEED=42

# Test split: first_n (default) uses the first NUM_QUESTIONS rows of test.json / test_gold.sql.
# balanced_16x4 = 64 total (16 per difficulty); preds: e.g. openai_few_shot.sql — NUM_QUESTIONS ignored.
# balanced_80x4 = 320 total (80 per difficulty); preds: e.g. openai_few_shot_balanced_80x4.sql — keeps 64-line runs separate.
# SPIDER_TEST_SPLIT=first_n
# SPIDER_TEST_SPLIT=balanced_16x4
# SPIDER_TEST_SPLIT=balanced_80x4

# Optional: first N questions when SPIDER_TEST_SPLIT=first_n (default 50)
NUM_QUESTIONS=50

# After generation, evaluate (examples):
#   python run_eval.py --pred baseline/results/cerebras_zero_shot.sql --etype exec
#   python run_eval.py --pred baseline/results/cerebras_chain_of_thought.sql --etype exec
#   python run_eval.py --pred baseline/results/cerebras_few_shot.sql --etype exec
#   python run_eval.py --pred baseline/results/openai_zero_shot.sql --etype exec
#   python run_eval.py --pred baseline/results/openai_self_correction.sql --etype exec
# 320 balanced (set SPIDER_TEST_SPLIT=balanced_80x4 for both baseline and run_eval):
#   python run_eval.py --pred baseline/results/openai_few_shot_balanced_80x4.sql --etype exec --skip-gold-write
# Dry run: python baseline/baseline_cerebras.py --strategy few_shot -n 1
# OpenAI dry run: python baseline/baseline_openai.py --strategy few_shot -n 1

# Legacy baselines
GROQ_API_KEY=
GEMINI_API_KEY=
